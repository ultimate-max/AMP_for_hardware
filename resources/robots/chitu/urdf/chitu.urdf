  <!-- ========== 虚拟FT传感器链接（左后腿） ========== -->
  <link name="RL_FT_wrist">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0001"/>
      <inertia ixx="1e-8" ixy="0" ixz="0" iyy="1e-8" iyz="0" izz="1e-8"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.0001"/></geometry>
      <material name="ft_sensor">
        <color rgba="1 0 0 0.5"/>
      </material>
    </visual>
  </link>
  <joint name="RL_ft_joint" type="fixed">
    <parent link="RL_calf"/>
    <child link="RL_FT_wrist"/>
    <origin xyz="0.275 -0.0 -0.278" rpy="0 0 0"/>
  </joint>
  <link name="RL_FOOT">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
      <mass value="0.1" />
