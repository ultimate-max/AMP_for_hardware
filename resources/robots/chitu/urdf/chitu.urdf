    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.041" />
      </geometry>
    </collision>
  </link>
  <joint name="RL_foot_fixed" type="fixed" dont_collapse="true">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="RL_FT_wrist"/>
    <child link="RL_FOOT"/>
  </joint>

